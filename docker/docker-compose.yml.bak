services:
  # Core API service
  core:
    build:
      context: ./core
    restart: unless-stopped
    depends_on:
      - database
      - redis
    environment:
      - DATABASE_URL=postgresql://postgres:postgres@database:5432/tesla
      - REDIS_URL=redis://redis:6379/0
      - LLM_SERVICE_URL=http://llm:8080
      - OPENCV_SERVICE_URL=http://opencv:8081
      - OBD_SERVICE_URL=http://obd:8082
      - LOG_LEVEL=info
      - JWT_SECRET=change_this_in_production
      - JWT_EXPIRATION=3600
    volumes:
      - core_data:/app/data
      - core_logs:/app/logs
      - shared_images:/app/images:ro
    ports:
      - "8000:8000"
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

  # LLM service
  llm:
    build:
      context: ./llm
    restart: unless-stopped
    environment:
      - MODEL_PATH=/app/models/llama3
      - ENABLE_GPU=false
      - CLOUD_FALLBACK=true
      - CLOUD_API_KEY=${CLOUD_API_KEY:-}
      - LOG_LEVEL=info
      - CORE_API_URL=http://core:8000
    volumes:
      - llm_models:/app/models
      - llm_logs:/app/logs
      - llm_config:/app/config
    ports:
      - "8080:8080"
    networks:
      - tesla_network
    deploy:
      resources:
        limits:
          memory: 6G
        reservations:
          memory: 4G
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  # OpenCV service
  opencv:
    build:
      context: ./opencv
    restart: unless-stopped
    environment:
      - CAMERA_SOURCE=/dev/video0
      - ENABLE_GPU=false
      - LOG_LEVEL=info
      - CORE_API_URL=http://core:8000
    volumes:
      - opencv_models:/app/models
      - opencv_logs:/app/logs
      - shared_images:/app/data/images
    ports:
      - "8081:8081"
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8081/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

  # OBD service
  obd:
    build:
      context: ./obd
    restart: unless-stopped
    environment:
      - OBD_DEVICE=/dev/ttyUSB0
      - CORE_API_URL=http://core:8000
      - LOG_LEVEL=info
    volumes:
      - obd_logs:/app/logs
      - obd_data:/app/data
    ports:
      - "8082:8082"
    devices: []
#      - /dev/ttyUSB0:/dev/ttyUSB0
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8082/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

  # Web UI
  webui:
    build:
      context: ./webui
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    depends_on:
      - core
      - llm
      - opencv
      - obd
    volumes:
      - ssl_data:/etc/nginx/ssl
      - ./webui/nginx.conf:/etc/nginx/conf.d/default.conf
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:80/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # Database
  database:
    image: postgres:14-alpine
    restart: unless-stopped
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB=tesla
    volumes:
      - db_data:/var/lib/postgresql/data
      - ./database/init-scripts:/docker-entrypoint-initdb.d
    ports:
      - "5432:5432"
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  # Redis for caching and messaging
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    volumes:
      - redis_data:/data
    ports:
      - "6379:6379"
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s

  # Prometheus
  prometheus:
    image: prom/prometheus:latest
    restart: unless-stopped
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus_data:/prometheus
    ports:
      - "9090:9090"
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:9090/-/healthy"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

  # Grafana
  grafana:
    image: grafana/grafana:latest
    restart: unless-stopped
    volumes:
      - grafana_data:/var/lib/grafana
      - ./monitoring/grafana/provisioning:/etc/grafana/provisioning
      - ./monitoring/grafana/dashboards:/var/lib/grafana/dashboards
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=admin
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource
    ports:
      - "3000:3000"
    depends_on:
      - prometheus
    networks:
      - tesla_network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

  # PostgreSQL exporter for Prometheus
  postgres-exporter:
    image: quay.io/prometheuscommunity/postgres-exporter:latest
    restart: unless-stopped
    environment:
      - DATA_SOURCE_NAME=postgresql://postgres:postgres@database:5432/tesla?sslmode=disable
    ports:
      - "9187:9187"
    depends_on:
      - database
    networks:
      - tesla_network

  # Redis exporter for Prometheus
  redis-exporter:
    image: oliver006/redis_exporter:latest
    restart: unless-stopped
    environment:
      - REDIS_ADDR=redis://redis:6379
    ports:
      - "9121:9121"
    depends_on:
      - redis
    networks:
      - tesla_network

  # Node exporter for system metrics
  node-exporter:
    image: quay.io/prometheus/node-exporter:latest
    restart: unless-stopped
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--path.rootfs=/rootfs'
      - '--collector.filesystem.ignored-mount-points=^/(sys|proc|dev|host|etc|rootfs/var/lib/docker/containers|rootfs/var/lib/docker/overlay2|rootfs/run/docker/netns|rootfs/var/lib/docker/aufs)(67829|/)'
    ports:
      - "9100:9100"
    networks:
      - tesla_network

  # cAdvisor for container metrics
  cadvisor:
    image: gcr.io/cadvisor/cadvisor:latest
    restart: unless-stopped
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
    ports:
      - "8088:8080"
    networks:
      - tesla_network

  # Tailscale VPN for secure remote access
  tailscale:
    image: tailscale/tailscale:latest
    restart: unless-stopped
    network_mode: host
    privileged: true
    environment:
      - TS_AUTHKEY=${TAILSCALE_AUTH_KEY:-}
      - TS_STATE_DIR=/var/lib/tailscale
    volumes:
      - tailscale_data:/var/lib/tailscale

  # Camera motion detection
  motion:
    image: thehomerepot/motioneye:latest
    restart: unless-stopped
    volumes:
      - motion_config:/etc/motioneye
      - motion_data:/var/lib/motioneye
      - shared_images:/var/lib/motioneye/camera
    ports:
      - "8765:8765"
    devices: []
    # Comment for testing: - /dev/video0:/dev/video0
    networks:
      - tesla_network

  # MQTT broker for IoT communication
  mosquitto:
    image: eclipse-mosquitto:latest
    restart: unless-stopped
    volumes:
      - ./mqtt/config:/mosquitto/config
      - mqtt_data:/mosquitto/data
      - mqtt_logs:/mosquitto/log
    ports:
      - "1883:1883"
      - "9001:9001"
    networks:
      - tesla_network

  # MQTT exporter for Prometheus
  mqtt-exporter:
    image: eclipse-mosquitto:latest
    restart: unless-stopped
    environment:
      - MQTT_URI=mqtt://mosquitto:1883
      - MQTT_USERNAME=teslaapi
      - MQTT_PASSWORD=teslaapi
    ports:
      - "9641:9641"
    depends_on:
      - mosquitto
    networks:
      - tesla_network

  # Backup service
  backup:
    image: offen/docker-volume-backup:latest
    restart: unless-stopped
    volumes:
      - core_data:/backup/core_data:ro
      - db_data:/backup/db_data:ro
      - shared_images:/backup/shared_images:ro
      - backup_data:/backup
    environment:
      - BACKUP_CRON_EXPRESSION=0 2 * * *
      - BACKUP_FILENAME=tesla-backup-%Y-%m-%d
      - BACKUP_RETENTION_DAYS=7
      - BACKUP_COMPRESSION_LEVEL=9
    networks:
      - tesla_network

networks:
  tesla_network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.0.0/16

volumes:
  core_data:
  core_logs:
  llm_models:
  llm_logs:
  llm_config:
  opencv_models:
  opencv_logs:
  obd_logs:
  obd_data:
  db_data:
  shared_images:
  prometheus_data:
  grafana_data:
  redis_data:
  tailscale_data:
  motion_config:
  motion_data:
  mqtt_data:
  mqtt_logs:
  ssl_data:
  backup_data:
