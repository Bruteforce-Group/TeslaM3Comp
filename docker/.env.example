# Tesla Model 3 Companion Environment Variables
# Copy this file to .env and fill in your values

# API keys for cloud services
CLOUD_API_KEY=your_openai_or_anthropic_api_key_here

# Tailscale for secure remote access
TAILSCALE_AUTH_KEY=your_tailscale_auth_key_here

# Security settings
JWT_SECRET=generate_a_strong_random_secret_key_here
JWT_EXPIRATION=3600

# Database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=tesla

# Redis password (optional but recommended)
REDIS_PASSWORD=change_this_to_a_secure_password

# MQTT authentication
MQTT_USERNAME=teslaapi
MQTT_PASSWORD=change_this_to_a_secure_password

# Email notifications (optional)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=your_email@example.com
SMTP_TO=destination_email@example.com

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Hardware settings
CAMERA_SOURCE=/dev/video0
OBD_DEVICE=/dev/ttyUSB0

# Enable GPU if available
ENABLE_GPU=false 